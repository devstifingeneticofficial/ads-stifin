generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   // PROMOTOR, KONTEN_KREATOR, ADVERTISER, STIFIN
  city      String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  adRequests    AdRequest[]
  notifications Notification[]
  contentAssignments AdRequest[] @relation("ContentCreatorAssignments")
  creatorPayoutBatches CreatorPayoutBatch[]
  promotorBonusBatches PromotorBonusBatch[]
}

model AdRequest {
  id              String          @id @default(cuid())
  city            String
  startDate       DateTime
  testEndDate     DateTime?
  durationDays    Int
  dailyBudget     Int
  totalBudget     Int
  ppn             Int
  totalPayment    Int
  status          String          @default("MENUNGGU_PEMBAYARAN")
  briefType       String?
  briefContent    String?
  briefVO         String?
  briefJJ         String?
  paymentProofUrl String?
  contentUrl      String?
  promotorNote    String?
  adStartDate     DateTime?
  adEndDate       DateTime?
  promotorId      String
  contentCreatorId String?
  promotor        User            @relation(fields: [promotorId], references: [id], onDelete: Cascade)
  contentCreator  User?           @relation("ContentCreatorAssignments", fields: [contentCreatorId], references: [id], onDelete: SetNull)
  adReport        AdReport?
  promotorResult  PromotorResult?
  creatorPayoutItem CreatorPayoutItem?
  promotorBonusItems PromotorBonusItem[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model AdReport {
  id          String    @id @default(cuid())
  adRequestId String    @unique
  adRequest   AdRequest @relation(fields: [adRequestId], references: [id], onDelete: Cascade)
  cpr         Float?
  totalLeads  Int?
  amountSpent Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PromotorResult {
  id           String    @id @default(cuid())
  adRequestId  String    @unique
  adRequest    AdRequest @relation(fields: [adRequestId], references: [id], onDelete: Cascade)
  totalClients Int
  previousTotalClients Int?
  note         String?
  status       String    @default("PENDING") // PENDING, VALID
  bonusPayoutItem PromotorBonusItem?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BriefTemplate {
  id        String   @id @default(cuid())
  type      String   // VO or JJ
  name      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NotificationTemplate {
  id        String   @id @default(cuid())
  slug      String   @unique // e.g., "payment-confirmed-promotor"
  name      String
  message   String
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model CreatorPayoutBatch {
  id           String   @id @default(cuid())
  creatorId    String
  creator      User     @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  payoutDate   DateTime @default(now())
  totalRequests Int
  totalContents Int
  totalAmount  Int
  transferProofUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items CreatorPayoutItem[]
}

model CreatorPayoutItem {
  id           String   @id @default(cuid())
  batchId      String
  batch        CreatorPayoutBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  adRequestId  String   @unique
  adRequest    AdRequest @relation(fields: [adRequestId], references: [id], onDelete: Cascade)
  requestAmount Int
  jjCount      Int      @default(3)
  voCount      Int      @default(1)
  contentCount Int      @default(4)
  createdAt    DateTime @default(now())
}

model PromotorBonusBatch {
  id            String   @id @default(cuid())
  promotorId    String
  promotor      User     @relation(fields: [promotorId], references: [id], onDelete: Cascade)
  payoutDate    DateTime @default(now())
  totalItems    Int
  totalClients  Int
  totalAmount   Int
  transferProofUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items PromotorBonusItem[]
}

model PromotorBonusItem {
  id              String   @id @default(cuid())
  batchId         String
  batch           PromotorBonusBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  promotorResultId String  @unique
  promotorResult  PromotorResult @relation(fields: [promotorResultId], references: [id], onDelete: Cascade)
  adRequestId     String
  adRequest       AdRequest @relation(fields: [adRequestId], references: [id], onDelete: Cascade)
  clientCount     Int
  bonusAmount     Int
  createdAt       DateTime @default(now())
}
